# ==============================================================================
# GetBnB Environment Variables Template
# Copy this file to a new file named '.env.local' in the root directory
# and replace the placeholders with your actual credentials.
# ==============================================================================

# Airtable Credentials (Personal Access Token & Base/Table IDs)
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_personal_access_token_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_APPLICATIONS_TABLE=Applications



